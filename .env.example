# Anthropic API ключ — для content engine, тематизации концептов, voice-doc v2.
# 1. Зарегистрироваться: console.anthropic.com
# 2. Создать API key: console.anthropic.com/settings/keys
# 3. Поставить hard-limit бюджета: console.anthropic.com/settings/limits
# ВАЖНО: никогда не отправлять ключ в чат / Slack / git — он попадёт в логи.
ANTHROPIC_API_KEY=

# HuggingFace токен для pyannote (диаризация спикеров).
# 1. Зарегистрироваться на huggingface.co
# 2. Принять лицензии:
#    https://huggingface.co/pyannote/speaker-diarization-3.1
#    https://huggingface.co/pyannote/segmentation-3.0
# 3. Создать токен (read): https://huggingface.co/settings/tokens
HF_TOKEN=

# Whisper-конфиг (опционально — переопределяет дефолты).
# CPU (Mac, слабые серверы): не задавать или device=cpu, compute_type=int8
# CUDA (NVIDIA GPU): задать device=cuda, compute_type=float16 — ИЛИ использовать
#   docker-compose.cuda.yml override, где они выставлены автоматически.
# WHISPER_DEVICE=cuda
# WHISPER_COMPUTE_TYPE=float16
# WHISPER_BATCH_SIZE=16

# Postgres (для будущих этапов, MVP-0+)
POSTGRES_USER=psy
POSTGRES_PASSWORD=psy
POSTGRES_DB=psy_helper
