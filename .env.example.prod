# Шаблон prod .env для psy-helper. На сервере положить как
# /home/deploy/psy-helper/.env и сделать chmod 600.

# === Streamlit auth ===
# Сгенерировать: openssl rand -hex 32
# Передать Ане через защищённый канал (Signal/Telegram), отдельно от URL.
STREAMLIT_PASSWORD=

# === Postgres ===
# Сгенерировать: openssl rand -hex 24
# Postgres не светится наружу (internal Docker network), но всё равно
# не оставлять дефолтное.
POSTGRES_PASSWORD=

# === Anthropic ===
# Отдельный prod-key, не тот что в локальном dev.
# В Anthropic Console → Workspaces → Settings → API Keys → Create.
# Поставь hard-limit $20-30/мес.
ANTHROPIC_API_KEY=